# ============================
# VERITAS Environment Variables
# ============================
# Copy this file to .env (backend) or .env.local (frontend) and fill in the values.
# NEVER commit .env or .env.local to version control.

# --- Groq API (4 dedicated keys — one per role) ---
GROQ_KEY_ANALYSIS=gsk_...    # Key 1 — repo/context analysis & orchestration
GROQ_KEY_QUESTIONS=gsk_...   # Key 2 — viva question generation
GROQ_KEY_EVALUATOR=gsk_...   # Key 3 — answer analysis (authenticity, reasoning, red flags)
GROQ_KEY_SCORING=gsk_...     # Key 4 — final score computation & tier assignment

# --- App ---
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://your-veritas-app.vercel.app
CORS_ALLOWED_ORIGINS=https://your-veritas-app.vercel.app

# ═══════════════════════════════════════════
# Frontend (Vite) — only VITE_ prefixed vars
# are exposed to the browser
# ═══════════════════════════════════════════
VITE_API_URL=https://your-veritas-backend.onrender.com
VITE_AI_ENABLED=true
